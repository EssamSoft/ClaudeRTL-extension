{
    "manifest_version": 3,
    "name": "Claude RTL",
    "version": "1.2",
    "description": "Inject custom RTL styles and layout adjustments into Claude.ai",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "https://claude.ai/*",
        "https://raw.githubusercontent.com/*"
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Claude RTL",
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://claude.ai/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
